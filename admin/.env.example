# Port the admin server listens on
PORT=4322

# Bind address. 0.0.0.0 to be reachable on the LAN/Tailscale, 127.0.0.1 to restrict to localhost only.
HOST=0.0.0.0

# Path to the wao-web git repository. Defaults to one directory up from admin/ (the repo root).
REPO_PATH=..

# Whether to automatically `git push` after each commit. Set to "false" to only commit locally.
AUTO_PUSH=true

# Optional, comma-separated list of Host header values to trust (e.g. the
# Tailscale IP:port you actually access this app at). Hardens the CSRF check
# against DNS rebinding. Leave unset to skip this extra check.
# ALLOWED_HOSTS=100.64.1.2:4322
